# СтройКонтроль AI — Environment Configuration
# Copy to .env and fill in production values

# Application
APP_NAME=СтройКонтроль AI
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-random-32-char-string

# Database — use SQLite for Windows dev, PostgreSQL for Linux/Docker
DATABASE_URL=sqlite+aiosqlite:///./stroikontrol_dev.db
# DATABASE_URL=postgresql://stroikontrol:stroikontrol@localhost:5432/stroikontrol

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=stroikontrol
MINIO_SECURE=false

# SMS Provider (mock, smsc, twilio)
SMS_PROVIDER=mock
SMS_API_KEY=
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=5

# Payments (yookassa, stripe)
PAYMENT_PROVIDER=yookassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# CORS
CORS_ORIGINS=["*"]
